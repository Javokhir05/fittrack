{
  "name": "fittrack-backend",
  "version": "1.0.0",
  "description": "FitTrack Health/Fitness Tracker API",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "lint": "eslint src/",
